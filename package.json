{
  "name": "slopsmith-desktop",
  "version": "0.2.3",
  "description": "Slopsmith desktop app with integrated audio engine, VST hosting, and amp modeling",
  "author": {
    "name": "Byron",
    "email": "byron@ougsoft.com"
  },
  "main": "dist/main/main.js",
  "scripts": {
    "build:ts": "tsc",
    "build:audio": "cmake-js build --runtime electron --runtime-version $(node -p \"require('electron/package.json').version\") --arch $(uname -m | sed 's/x86_64/x64/' | sed 's/aarch64/arm64/') --CDCMAKE_BUILD_TYPE=Release",
    "build:audio:debug": "cmake-js build --runtime electron --runtime-version $(node -p \"require('electron/package.json').version\") --CDCMAKE_BUILD_TYPE=Debug",
    "rebuild:audio": "cmake-js rebuild --runtime electron --runtime-version $(node -p \"require('electron/package.json').version\")",
    "build:rscli": "bash scripts/build-rscli.sh",
    "build:native": "npm run build:audio && npm run build:rscli",
    "bundle:slopsmith": "bash scripts/bundle-slopsmith.sh",
    "bundle:python": "bash scripts/bundle-python.sh",
    "bundle:binaries": "bash scripts/bundle-binaries.sh",
    "bundle:soundfont": "bash scripts/bundle-soundfont.sh",
    "bundle": "bash scripts/bundle.sh",
    "start": "npm run build:ts && electron .",
    "dev": "tsc && electron .",
    "dist": "npm run bundle && npm run build:ts && electron-builder",
    "dist:linux": "npm run dist -- --linux",
    "dist:mac": "npm run dist -- --mac",
    "dist:win": "npm run dist -- --win",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.byron.slopsmith-desktop",
    "productName": "Slopsmith",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "build/Release/*.node"
    ],
    "extraResources": [
      {
        "from": "resources/slopsmith",
        "to": "slopsmith"
      },
      {
        "from": "resources/python",
        "to": "python"
      },
      {
        "from": "resources/bin",
        "to": "bin"
      },
      {
        "from": "resources/default-irs",
        "to": "default-irs"
      },
      {
        "from": "resources/soundfonts",
        "to": "soundfonts"
      }
    ],
    "asarUnpack": [
      "build/Release/*.node"
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Audio",
      "icon": "resources/icons"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.music",
      "icon": "resources/icons/icon.icns",
      "identity": null,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Slopsmith needs microphone access for guitar input and note detection."
      }
    },
    "win": {
      "target": ["nsis"],
      "icon": "resources/icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "node-addon-api": "^8.3.1"
  },
  "devDependencies": {
    "cmake-js": "^7.3.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  },
  "cmake-js": {
    "runtime": "electron"
  }
}
